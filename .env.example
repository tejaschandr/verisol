# Solidity Compiler
SOLC_VERSION=0.8.24

# Verification Timeouts (seconds)
SLITHER_TIMEOUT=60
SMTCHECKER_TIMEOUT=120

# LLM Configuration
LLM_ENABLED=true
LLM_PROVIDER=openai  # or "anthropic"
# LLM_MODEL=gpt-4o  # defaults to gpt-4o (openai) or claude-sonnet-4-20250514 (anthropic)
LLM_TIMEOUT=120
LLM_ENABLE_FILTERS=true

# Exploit Generation (LLM agent)
EXPLOIT_LLM_ENABLED=true
# EXPLOIT_LLM_PROVIDER=openai       # defaults to LLM_PROVIDER
# EXPLOIT_LLM_MODEL=gpt-4o          # defaults to provider default
EXPLOIT_MAX_RETRIES=3

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
# API_CORS_ORIGINS=*

# API Keys (at least one required for LLM verification)
OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Etherscan API Key (for --address flag)
# ETHERSCAN_API_KEY=your-etherscan-key-here

# Fork Mode RPC URLs (for --exploit with --address)
# ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-key
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your-key
# ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/your-key
# OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/your-key
# BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your-key

# Fork Timeout (seconds, default 180)
# FORK_TIMEOUT=180
