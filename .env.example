# Solidity Compiler
SOLC_VERSION=0.8.24

# Verification Timeouts (seconds)
SLITHER_TIMEOUT=60
SMTCHECKER_TIMEOUT=120

# LLM Configuration
LLM_ENABLED=true
LLM_PROVIDER=openai  # or "anthropic"
# LLM_MODEL=gpt-4o  # defaults to gpt-4o (openai) or claude-sonnet-4-20250514 (anthropic)
LLM_TIMEOUT=120
LLM_ENABLE_FILTERS=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# API Keys (at least one required for LLM verification)
OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Data Paths
CONTRACTS_DIR=./data/contracts
REPORTS_DIR=./data/reports
